# ─── Server-side secrets (used by server.js) ────────────────────────────────
# Stripe secret key. Without it, checkout returns a friendly "not configured" error.
STRIPE_SECRET_KEY=sk_test_xxx

# Port the server listens on. Railway sets this automatically — leave unset locally
# to default to 3001 (the CRA dev proxy target).
# PORT=3001

# ─── Client-side, build-time (must be prefixed REACT_APP_) ──────────────────
# These are inlined into the static bundle at build time, so they are public.
REACT_APP_INSTAGRAM_URL=https://instagram.com/yourhandle
REACT_APP_TIKTOK_URL=https://tiktok.com/@yourhandle
REACT_APP_LINKEDIN_URL=https://linkedin.com/company/yourhandle
